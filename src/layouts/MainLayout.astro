---
import type { Langs } from "@interfaces/lang";

import { Font } from "astro:assets";

import "@/styles/global.css";

import labelGeneral from "@lang/general.json";

import MetaPixelHead from "@components/base/MetaPixelHead.astro";
import MetaPixelBody from "@components/base/MetaPixelBody.astro";
import GoogleTagManagerHead from "@components/base/GoogleTagManagerHead.astro";
import GoogleTagManagerBody from "@components/base/GoogleTagManagerBody.astro";
import OpenGraph from "@components/base/OpenGraph.astro";

interface Props {
  lang: Langs;
  title: string;
  description: string;
  opengraphImage: string;
}

const { lang, title, description, opengraphImage } = Astro.props;

const currentDate = new Date();
currentDate.setMinutes(currentDate.getMinutes() - currentDate.getTimezoneOffset());
---

<!doctype html>
<html lang={lang} class="h-full scroll-smooth" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={`${Astro.site?.href}/favicon.png`} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Mosketeros Group">
    <meta name="copyright" content={labelGeneral.COPYRIGHT[lang]} />
    <meta name="robots" content="index, follow">
    <meta name="lastbuild" content={currentDate.toISOString().slice(0, 16)} />
    <link rel="canonical" href={Astro.url} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script src="/src/scripts/mode.ts"></script>
    <script src="/src/scripts/scripts.ts"></script>
    <slot name="head" />
    <title>{title}</title>

    <GoogleTagManagerHead />
    <MetaPixelHead />
    <OpenGraph lang={lang} title={title} description={description} opengraphImage={opengraphImage} />

    <Font cssVariable="--font-roboto" preload />
    <Font cssVariable="--font-roboto-italic" preload />
  </head>
  <body class="font-roboto clamp-[py,5,10] clamp-[text,sm,base] text-balance bg-background text-foreground">
    <GoogleTagManagerBody />
    <MetaPixelBody />

    <slot />
  </body>
</html>
