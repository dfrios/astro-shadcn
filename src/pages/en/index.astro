---
import MainLayout from "@layouts/MainLayout.astro";

import Header from "@components/sections/Header.astro";
import Footer from "@components/sections/Footer.astro";

import indexLabels from "@lang/index.json";

const lang = "en";
---

<MainLayout
  lang={lang}
  title={indexLabels.PAGE_TITLE[lang]}
  description={indexLabels.PAGE_DESCRIPTION[lang]}
  opengraphImage="home.jpg"
>
  <Header lang={lang} />
  <p class="font-roboto font-light">Roboto Light</p>
  <p class="font-roboto">Roboto Regular</p>
  <p class="font-roboto font-bold">Roboto Bold</p>
  <Footer lang={lang} />
</MainLayout>
